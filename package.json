{
  "name": "open-dev-browser",
  "version": "1.0.0",
  "description": "MCP server for browser automation with persistent Playwright sessions",
  "type": "module",
  "bin": {
    "open-dev-browser": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx --test test/**/*.test.ts",
    "audit": "npm audit --audit-level=moderate",
    "verify": "npm run typecheck && npm run build && npm test && npm pack --dry-run",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "ajv": "^8.18.0",
    "path-to-regexp": "^8.4.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["mcp", "playwright", "browser", "automation", "opencode", "claude", "ai"],
  "license": "MIT",
  "author": "George Stander",
  "repository": {
    "type": "git",
    "url": "https://github.com/georgestander/open-dev-browser.git"
  },
  "bugs": {
    "url": "https://github.com/georgestander/open-dev-browser/issues"
  },
  "homepage": "https://github.com/georgestander/open-dev-browser#readme"
}
